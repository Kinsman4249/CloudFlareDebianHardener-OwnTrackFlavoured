#!/usr/bin/env bash
# cf-owntracks-refresh
# Fetches Cloudflare IP ranges (and AOP CA cert if mTLS enabled), validates,
# and atomically updates the firewall + nginx snippets.
#
# Runs daily via systemd timer; flock-protected against overlap.
# Exits non-zero on any failure (refusing to apply suspicious data).

set -Eeuo pipefail

CFO_LIB_DIR="${CFO_LIB_DIR:-/usr/local/lib/cf-owntracks}"
# shellcheck disable=SC1091
source "${CFO_LIB_DIR}/common.sh"

require_root

# Take an exclusive lock; bail if another run is in progress.
exec 9>"${CFO_LOCK_FILE}"
if ! flock -n 9; then
    log_error "another refresh is in progress; exiting"
    exit 0
fi

load_config

case "${CFO_FW_BACKEND}" in
    nftables) source "${CFO_LIB_DIR}/nftables.sh" ;;
    ufw)      source "${CFO_LIB_DIR}/ufw.sh" ;;
    iptables) source "${CFO_LIB_DIR}/iptables.sh" ;;
    *) die "unknown firewall backend: ${CFO_FW_BACKEND}" ;;
esac

# ---- Workspace ---------------------------------------------------------------
WORK_DIR="$(mktemp -d -t cf-owntracks.XXXXXX)"
cleanup() { rm -rf "$WORK_DIR"; }
trap cleanup EXIT

V4_NEW="${WORK_DIR}/ips-v4.new"
V6_NEW="${WORK_DIR}/ips-v6.new"
V4_VALID="${WORK_DIR}/ips-v4.valid"
V6_VALID="${WORK_DIR}/ips-v6.valid"
NFT_NEW="${WORK_DIR}/ruleset.nft"
IPT_V4_NEW="${WORK_DIR}/ruleset.v4"
IPT_V6_NEW="${WORK_DIR}/ruleset.v6"

REALIP_NEW="${WORK_DIR}/cloudflare-realip.conf"
ALLOW_NEW="${WORK_DIR}/cloudflare-allow.conf"
MTLS_NEW="${WORK_DIR}/cloudflare-mtls.conf"
AOP_CA_NEW="${WORK_DIR}/origin-pull-ca.pem"

# Backups of the files we'll replace (for rollback).
REALIP_BAK="${WORK_DIR}/cloudflare-realip.bak"
ALLOW_BAK="${WORK_DIR}/cloudflare-allow.bak"
MTLS_BAK="${WORK_DIR}/cloudflare-mtls.bak"
FW_BAK="${WORK_DIR}/firewall.bak"

# ---- 1. Fetch Cloudflare IP lists -------------------------------------------
log_info "fetching Cloudflare IP ranges"
fetch_with_retry "$CFO_IPS_V4_URL" "$V4_NEW" || die "failed to fetch IPv4 list"
fetch_with_retry "$CFO_IPS_V6_URL" "$V6_NEW" || die "failed to fetch IPv6 list"

# ---- 2. Validate CIDR format ------------------------------------------------
validate_cidr_list v4 < "$V4_NEW" > "$V4_VALID" || die "IPv4 validation failed"
validate_cidr_list v6 < "$V6_NEW" > "$V6_VALID" || die "IPv6 validation failed"

v4_count=$(grep -c . "$V4_VALID" || true)
v6_count=$(grep -c . "$V6_VALID" || true)
log_info "fetched ${v4_count} IPv4 + ${v6_count} IPv6 ranges"

if (( v4_count < CFO_MIN_V4_RANGES )); then
    die "IPv4 count ${v4_count} below threshold ${CFO_MIN_V4_RANGES}"
fi
if (( v6_count < CFO_MIN_V6_RANGES )); then
    die "IPv6 count ${v6_count} below threshold ${CFO_MIN_V6_RANGES}"
fi

# ---- 3. Sanity-check delta vs last-known-good -------------------------------
check_delta "$V4_VALID" "$CFO_IPS_V4_FILE" v4 || die "IPv4 delta exceeded threshold"
check_delta "$V6_VALID" "$CFO_IPS_V6_FILE" v6 || die "IPv6 delta exceeded threshold"

# ---- 4. (mTLS) Fetch + validate Cloudflare origin-pull CA -------------------
AOP_NEEDS_UPDATE=0
if [[ "${CFO_MTLS_ENABLED}" == "1" ]]; then
    if fetch_with_retry "$CFO_AOP_CA_URL" "$AOP_CA_NEW"; then
        if ! openssl x509 -in "$AOP_CA_NEW" -noout 2>/dev/null; then
            die "fetched origin-pull CA is not a valid x509 certificate"
        fi
        local_hash=""
        new_hash="$(sha256sum "$AOP_CA_NEW" | awk '{print $1}')"
        if [[ -f "$CFO_AOP_CA_HASH" ]]; then
            local_hash="$(cat "$CFO_AOP_CA_HASH" 2>/dev/null || true)"
        fi
        if [[ "$new_hash" != "$local_hash" ]]; then
            log_info "origin-pull CA changed (was: ${local_hash:0:12}…  now: ${new_hash:0:12}…)"
            AOP_NEEDS_UPDATE=1
        fi
    else
        # Don't fail the whole run if we can't reach the CA URL — keep using current CA.
        log_warn "origin-pull CA fetch failed; continuing with existing CA"
    fi
fi

# ---- 5. Render nginx snippets ------------------------------------------------
{
    echo "# Generated by cf-owntracks-refresh on $(date -u +%FT%TZ)"
    echo "# DO NOT EDIT — managed file"
    echo "real_ip_header CF-Connecting-IP;"
    echo "real_ip_recursive on;"
    while IFS= read -r cidr; do
        [[ -n "$cidr" ]] && echo "set_real_ip_from ${cidr};"
    done < "$V4_VALID"
    while IFS= read -r cidr; do
        [[ -n "$cidr" ]] && echo "set_real_ip_from ${cidr};"
    done < "$V6_VALID"
} > "$REALIP_NEW"

{
    echo "# Generated by cf-owntracks-refresh on $(date -u +%FT%TZ)"
    echo "# DO NOT EDIT — managed file"
    while IFS= read -r cidr; do
        [[ -n "$cidr" ]] && echo "allow ${cidr};"
    done < "$V4_VALID"
    while IFS= read -r cidr; do
        [[ -n "$cidr" ]] && echo "allow ${cidr};"
    done < "$V6_VALID"
    echo "deny all;"
} > "$ALLOW_NEW"

if [[ "${CFO_MTLS_ENABLED}" == "1" ]]; then
    cat > "$MTLS_NEW" <<EOF
# Generated by cf-owntracks-refresh on $(date -u +%FT%TZ)
# DO NOT EDIT — managed file
ssl_client_certificate ${CFO_AOP_CA_FILE};
ssl_verify_client on;
EOF
fi

# ---- 6. Render firewall ruleset ---------------------------------------------
case "${CFO_FW_BACKEND}" in
    nftables)
        nftables_render "$V4_VALID" "$V6_VALID" > "$NFT_NEW"
        if ! nftables_check "$NFT_NEW" >/dev/null; then
            die "nftables ruleset failed validation"
        fi
        ;;
    iptables)
        iptables_render_v4 "$V4_VALID" > "$IPT_V4_NEW"
        iptables_render_v6 "$V6_VALID" > "$IPT_V6_NEW"
        if ! iptables_check "$IPT_V4_NEW" "$IPT_V6_NEW" >/dev/null; then
            die "iptables ruleset failed validation"
        fi
        ;;
    ufw)
        : # ufw applies imperatively; no separate render step
        ;;
esac

# ---- 7. Backup existing files (for rollback) --------------------------------
[[ -f "$CFO_NGINX_REALIP_SNIPPET" ]] && cp -p "$CFO_NGINX_REALIP_SNIPPET" "$REALIP_BAK"
[[ -f "$CFO_NGINX_ALLOW_SNIPPET" ]]  && cp -p "$CFO_NGINX_ALLOW_SNIPPET"  "$ALLOW_BAK"
[[ -f "$CFO_NGINX_MTLS_SNIPPET" ]]   && cp -p "$CFO_NGINX_MTLS_SNIPPET"   "$MTLS_BAK"

case "${CFO_FW_BACKEND}" in
    nftables) nftables_snapshot "$FW_BAK" ;;
    ufw)      ufw_snapshot "$FW_BAK" ;;
    iptables) iptables_snapshot "$FW_BAK" ;;
esac

# ---- 8. Apply nginx snippets, test, reload ----------------------------------
log_info "installing new nginx snippets"
install -m 0644 "$REALIP_NEW" "$CFO_NGINX_REALIP_SNIPPET"
install -m 0644 "$ALLOW_NEW"  "$CFO_NGINX_ALLOW_SNIPPET"
if [[ "${CFO_MTLS_ENABLED}" == "1" ]]; then
    install -m 0644 "$MTLS_NEW" "$CFO_NGINX_MTLS_SNIPPET"
    if (( AOP_NEEDS_UPDATE == 1 )) && [[ -s "$AOP_CA_NEW" ]]; then
        mkdir -p "$(dirname "$CFO_AOP_CA_FILE")"
        install -m 0644 "$AOP_CA_NEW" "$CFO_AOP_CA_FILE"
        sha256sum "$CFO_AOP_CA_FILE" | awk '{print $1}' > "$CFO_AOP_CA_HASH"
        log_info "updated origin-pull CA cert"
    fi
fi

rollback_nginx() {
    log_warn "rolling back nginx snippets"
    [[ -f "$REALIP_BAK" ]] && cp -p "$REALIP_BAK" "$CFO_NGINX_REALIP_SNIPPET" || rm -f "$CFO_NGINX_REALIP_SNIPPET"
    [[ -f "$ALLOW_BAK" ]]  && cp -p "$ALLOW_BAK"  "$CFO_NGINX_ALLOW_SNIPPET"  || rm -f "$CFO_NGINX_ALLOW_SNIPPET"
    [[ -f "$MTLS_BAK" ]]   && cp -p "$MTLS_BAK"   "$CFO_NGINX_MTLS_SNIPPET"   || rm -f "$CFO_NGINX_MTLS_SNIPPET"
}

if ! nginx -t 2>&1; then
    rollback_nginx
    nginx -t >/dev/null 2>&1 || log_error "nginx config is broken even after rollback — manual intervention required"
    die "nginx -t failed with new snippets; rolled back"
fi

if ! nginx -s reload 2>&1; then
    rollback_nginx
    nginx -s reload >/dev/null 2>&1 || log_error "nginx reload failed even after rollback"
    die "nginx reload failed; rolled back"
fi

# ---- 9. Apply firewall (with rollback on failure) ---------------------------
log_info "applying firewall changes"
fw_apply_failed=0
case "${CFO_FW_BACKEND}" in
    nftables) nftables_apply "$NFT_NEW"             || fw_apply_failed=1 ;;
    ufw)      ufw_apply      "$V4_VALID" "$V6_VALID" || fw_apply_failed=1 ;;
    iptables) iptables_apply "$IPT_V4_NEW" "$IPT_V6_NEW" || fw_apply_failed=1 ;;
esac

if (( fw_apply_failed == 1 )); then
    log_error "firewall apply failed; rolling back nginx and firewall"
    case "${CFO_FW_BACKEND}" in
        nftables) nftables_restore "$FW_BAK" ;;
        ufw)      ufw_restore      "$FW_BAK" ;;
        iptables) iptables_restore "$FW_BAK" ;;
    esac
    rollback_nginx
    nginx -s reload || true
    die "firewall apply failed; state restored"
fi

# Persist firewall changes across reboot (best-effort)
case "${CFO_FW_BACKEND}" in
    nftables) nftables_persist ;;
    ufw)      ufw_persist ;;
    iptables) iptables_persist ;;
esac

# ---- 10. Promote last-known-good --------------------------------------------
mkdir -p "$CFO_STATE_DIR"
install -m 0644 "$V4_VALID" "$CFO_IPS_V4_FILE"
install -m 0644 "$V6_VALID" "$CFO_IPS_V6_FILE"

log_info "refresh complete: ${v4_count} IPv4 + ${v6_count} IPv6 ranges; mtls=${CFO_MTLS_ENABLED}"
